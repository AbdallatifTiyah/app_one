<odoo>
    <record id="building_view_list" model="ir.ui.view">
        <field name="name">building tree</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <list class="header_custom">
                <field name="name"/>
                <field name="no"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="building_view_form" model="ir.ui.view">
        <field name="name">building form</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="General Info.">
                            <field name="name"/>
                            <field name="no"/>
                        </group>
                        <group string="Additional Info.">
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

